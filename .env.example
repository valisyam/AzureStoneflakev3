# Environment Variables for Azure Deployment

# Database Configuration
DATABASE_URL=postgresql://username:password@server.postgres.database.azure.com:5432/database?ssl=true

# Authentication
JWT_SECRET=your-secure-jwt-secret-key-here

# Email Service (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Application Settings
NODE_ENV=production
PORT=8080

# PostgreSQL Connection Details (for Azure Database for PostgreSQL)
PGHOST=your-server.postgres.database.azure.com
PGPORT=5432
PGUSER=your-username
PGPASSWORD=your-password
PGDATABASE=stoneflake_manufacturing